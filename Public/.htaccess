<IfModule mod_rewrite.c>
    Options -MultiViews
    RewriteEngine On

    # Stop processing if the file or directory exists in /public
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # Send everything else to index.php
    RewriteRule ^ index.php [L,QSA]
</IfModule>